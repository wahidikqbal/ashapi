# Database Configuration
DATABASE_URL=ecto://postgres:postgres@localhost:5432/ashapi_dev

# Server Configuration
PORT=4000
PHX_HOST=localhost:4000

# Secrets
SECRET_KEY_BASE=your-secret-key-base-here-run-mix-phx-gen-secret
TOKEN_SIGNING_SECRET=your-token-signing-secret-here

# CORS Configuration (for development)
# For production, set this to your actual domain(s)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:5174

# Optional: Additional configuration
# DNS_CLUSTER_QUERY=
# ECTO_IPV6=false
# POOL_SIZE=10
